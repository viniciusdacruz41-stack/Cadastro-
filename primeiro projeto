<!DOCTYPE html>
<html lang="pt-br">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Cadastro de Usuário</title>

    <link rel="stylesheet" href="style.css">

</head>const form = document.getElementById("formCadastro");

const senha = document.getElementById("senha");

const confirmacao = document.getElementById("confirmacao");

form.addEventListener("submit", function(event) {

    if (senha.value !== confirmacao.value) {

        event.preventDefault();

        alert("As senhas não coincidem!");

    }

    else {

        alert("Cadastro realizado com sucesso!");

    }

});

<body>

    <header>

        <h1>Cadastre-se Aqui</h1>

    </header>

    <div class="container">

        <form id="formCadastro">

            <h2>Cadastro de Usuário</h2>

            <!-- Nome -->
            <div class="campo">

                <label>Nome</label>

                <input
                    type="text"
                    id="nome"
                    placeholder="Digite seu nome"
                    required
                >

            </div>

            <!-- Email -->
            <div class="campo">

                <label>E-mail</label>

                <input
                    type="email"
                    id="email"
                    placeholder="Digite seu e-mail"
                    required
                >

            </div>

            <!-- Data -->
            <div class="campo">

                <label>Data de Nascimento</label>

                <input
                    type="date"
                    required
                >

            </div>

            <!-- Gênero -->
            <div class="campo">

                <label>Gênero</label>

                <select required>

                    <option value="">
                        Selecione
                    </option>

                    <option value="masculino">
                        Masculino
                    </option>

                    <option value="feminino">
                        Feminino
                    </option>

                    <option value="outro">
                        Outro
                    </option>

                </select>

            </div>

            <!-- Senha -->
            <div class="campo">

                <label>Senha</label>

                <input
                    type="password"
                    id="senha"
                    placeholder="Digite sua senha"
                    minlength="6"
                    required
                >

            </div>

            <!-- Confirmar -->
            <div class="campo">

                <label>Confirmar Senha</label>

                <input
                    type="password"
                    id="confirmacao"
                    placeholder="Confirme sua senha"
                    minlength="6"
                    required
                >

            </div>

            <button type="submit">
                Cadastrar
            </button>

        </form>

    </div>/* BODY */

body {

    margin: 0;
    padding: 0;

    font-family: Arial, sans-serif;

    background: linear-gradient(to right, #001133, #4da6ff);

    height: 100vh;

    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
}

/* HEADER */

header {

    text-align: center;

    margin-bottom: 20px;
}

header h1 {

    color: #bfe6ff;

    font-size: 42px;

    text-shadow: 2px 2px 12px rgba(173, 216, 255, 0.7);
}

/* CONTAINER */

.container {

    width: 380px;

    background: #002244;

    padding: 30px;

    border-radius: 15px;

    box-shadow: 0 0 25px rgba(77, 166, 255, 0.5);
}

/* TÍTULO */

h2 {

    text-align: center;

    color: #bfe6ff;

    margin-bottom: 25px;
}

/* CAMPOS */

.campo {

    margin-bottom: 18px;
}

.campo label {

    display: block;

    margin-bottom: 6px;

    color: white;

    font-weight: bold;
}

/* INPUTS */

.campo input,
.campo select {

    width: 100%;

    padding: 12px;

    border: 1px solid #66b3ff;

    border-radius: 8px;

    background-color: #003366;

    color: white;

    outline: none;

    box-sizing: border-box;

    transition: 0.3s;
}

/* EFEITO AO CLICAR */

.campo input:focus,
.campo select:focus {

    border-color: #bfe6ff;

    box-shadow: 0 0 12px rgba(191, 230, 255, 0.8);
}

/* BOTÃO */

button {

    width: 100%;

    padding: 14px;

    border: none;

    border-radius: 8px;

    background: #66b3ff;

    color: #001133;

    font-size: 16px;

    font-weight: bold;

    cursor: pointer;

    transition: 0.3s;
}

/* HOVER */

button:hover {

    background: #99ccff;

    transform: scale(1.03);
}
<footer>
    Desenvolvido por Vinícius Nogueira • 13 de maio de 2026
</footer>
    <script src="script.js"></script>

</body>

</html>
